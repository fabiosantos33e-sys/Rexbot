module.exports = {
  async execute(interaction) {

    const sub =
      interaction.options.getSubcommand();

    if (sub === "tocar") {

      const nome =
        interaction.options.getString("nome");

      return interaction.reply(
        `🎵 Tocaria: ${nome}`
      );

    }

    if (sub === "parar") {

      return interaction.reply(
        "⏹️ Música parada"
      );

    }

  }
};
